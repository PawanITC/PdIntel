# Copy to .env, fill in values, then run: source .env && bash deploy.sh

export TF_VAR_aws_region=eu-west-2
export TF_VAR_app_name=plany-payment-service
export TF_VAR_vpc_id=
export TF_VAR_kinesis_stream_name=pd-payment-kinesis-euw2

# Existing RDS — paste values from your current env/config
export TF_VAR_db_url=
export TF_VAR_db_username=
export TF_VAR_db_password=

export TF_VAR_stripe_api_key=
export TF_VAR_stripe_webhook_secret=
export TF_VAR_cognito_issuer_uri=

# ALB costs ~$18/month — leave false for testing, set true for staging/prod
export TF_VAR_enable_alb=false

# Fargate sizing
export TF_VAR_task_cpu=256
export TF_VAR_task_memory=1024

# Optional: override the Docker image tag (default: latest)
# export IMAGE_TAG=v1.0.0
